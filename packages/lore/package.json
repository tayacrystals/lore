{
  "name": "@tayacrystals/lore",
  "version": "1.0.3",
  "description": "Simple documentation site generator with versioning and internationalization support",
  "type": "module",
  "bin": {
    "lore": "src/index.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./parse": "./src/parse.ts",
    "./types": "./src/types.ts",
    "./plugins": "./src/plugins.ts"
  },
  "workspaces": [
    "packages/*"
  ],
  "files": [
    "src"
  ],
  "scripts": {
    "build": "bun run src/index.ts build",
    "dev": "bun run src/index.ts dev",
    "serve": "bun run src/index.ts serve"
  },
  "keywords": [
    "documentation",
    "static-site-generator",
    "docs",
    "markdown",
    "mdx",
    "cli"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tayacrystals/lore.git"
  },
  "homepage": "https://github.com/tayacrystals/lore#readme",
  "bugs": {
    "url": "https://github.com/tayacrystals/lore/issues"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "lucide": "^0.577.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.0.2",
    "unified": "^11.0.5"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
